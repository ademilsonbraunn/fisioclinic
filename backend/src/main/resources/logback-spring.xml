<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ── Console (desenvolvimento) ──────────────────────────────────────── -->
  <springProfile name="!prod">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
  </springProfile>

  <!-- ── Arquivo com rotação (produção e desenvolvimento) ───────────────── -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/fisioclinic.log</file>

    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- Rotação diária; manter no máximo 30 dias; comprimir arquivos antigos -->
      <fileNamePattern>logs/fisioclinic.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <!-- Cap total em disco: 500 MB -->
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>

    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ── Níveis por pacote ───────────────────────────────────────────────── -->
  <logger name="com.fisioclinic" level="${LOG_LEVEL:-INFO}"/>
  <logger name="org.springframework.security" level="WARN"/>
  <logger name="org.hibernate.SQL" level="WARN"/>
  <logger name="org.springframework.web" level="WARN"/>

  <!-- ── Root ───────────────────────────────────────────────────────────── -->
  <root level="WARN">
    <springProfile name="!prod">
      <appender-ref ref="CONSOLE"/>
    </springProfile>
    <appender-ref ref="FILE"/>
  </root>

</configuration>
